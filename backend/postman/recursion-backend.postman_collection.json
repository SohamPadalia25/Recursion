  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register (student/instructor/admin) [multipart]",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "multipart/form-data" }
            ],
            "url": "{{baseUrl}}/users/register",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "fullname", "value": "Test User" },
                { "key": "username", "value": "student1" },
                { "key": "email", "value": "student1@example.com" },
                { "key": "password", "value": "Password123!" },
                { "key": "role", "value": "student" },
                { "key": "avatar", "type": "file", "src": "{{avatarFile}}" },
                { "key": "coverImage", "type": "file", "src": "{{coverImageFile}}" }
              ]
            }
          }
        },
        {
          "name": "Login (student) [sets accessTokenStudent]",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{usernameStudent}}\",\n  \"password\": \"{{passwordStudent}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const data = json?.data;",
                  "if (data?.accessToken) pm.collectionVariables.set('accessTokenStudent', data.accessToken);",
                  "if (data?.refreshToken) pm.collectionVariables.set('refreshTokenStudent', data.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (instructor) [sets accessTokenInstructor]",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{usernameInstructor}}\",\n  \"password\": \"{{passwordInstructor}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const data = json?.data;",
                  "if (data?.accessToken) pm.collectionVariables.set('accessTokenInstructor', data.accessToken);",
                  "if (data?.refreshToken) pm.collectionVariables.set('refreshTokenInstructor', data.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (admin) [sets accessTokenAdmin]",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{usernameAdmin}}\",\n  \"password\": \"{{passwordAdmin}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const data = json?.data;",
                  "if (data?.accessToken) pm.collectionVariables.set('accessTokenAdmin', data.accessToken);",
                  "if (data?.refreshToken) pm.collectionVariables.set('refreshTokenAdmin', data.refreshToken);"
                ]
              }
            }
          ]
        },
