        {
          "name": "Get my badges (student)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessTokenStudent}}" }
            ],
            "url": "{{baseUrl}}/users/my-badges"
          }
        }
        ,
