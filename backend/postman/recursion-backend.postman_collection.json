            "url": "{{baseUrl}}/courses/my-courses"
          }
        },
        {
          "name": "Update course [multipart] (instructor)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessTokenInstructor}}" },
              { "key": "Content-Type", "value": "multipart/form-data" }
            ],
            "url": "{{baseUrl}}/courses/{{courseId}}",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Node Basics (Updated)" },
                { "key": "thumbnail", "type": "file", "src": "{{thumbnailFile}}" }
              ]
            }
          }
        },
        {
          "name": "Submit course for approval (instructor)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessTokenInstructor}}" }
