            ],
            "url": "{{baseUrl}}/users/{{studentId}}"
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Get all courses (public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/courses?category=&level=&search=&page=1&limit=12"
          }
        },
        {
          "name": "Create course [multipart] (instructor)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessTokenInstructor}}" }
            ],
            "url": "{{baseUrl}}/courses",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Node Basics" },
                { "key": "description", "value": "Learn Node.js from scratch." },
                { "key": "category", "value": "Backend" },
                { "key": "price", "value": "49" },
                { "key": "level", "value": "beginner" },
                { "key": "language", "value": "English" },
                { "key": "tags", "value": "node,express,backend" },
                { "key": "thumbnail", "type": "file", "src": "{{thumbnailFile}}" }
              ]
            }
          }
        },
        {
          "name": "Get course (public) by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/courses/{{courseId}}"
          }
        },
        {
          "name": "My courses (instructor)",
          "request": {
